# ─── Postgres ────────────────────────────────────────────────────
POSTGRES_DB=hearthline
POSTGRES_USER=hearthline
POSTGRES_PASSWORD=hearthline_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── Django ──────────────────────────────────────────────────────
# Set DJANGO_DEBUG=0 in production. Generate a long random SECRET_KEY.
DJANGO_SECRET_KEY=change-me-in-prod-this-is-just-for-local-dev
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# REQUIRED IN PROD. Used to encrypt per-business API keys at rest in Postgres.
# Generate one with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# Rotating this value invalidates all stored credentials — set it once and back it up.
HEARTHLINE_ENCRYPTION_KEY=

# Default log level for app loggers (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
HEARTHLINE_LOG_LEVEL=INFO

# In production: which Vercel origin is allowed to call the API.
# Comma-separated list, no trailing slash.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Production VPS deploy (used by docker-compose.prod.yml + Caddy) ───
# Public hostname Caddy serves the backend on. Caddy issues a Let's Encrypt cert for this.
API_DOMAIN=api.hearthline.codewithmuh.com
# Vercel frontend origin — Caddy forwards CORS allowlist here.
FRONTEND_ORIGIN=https://hearthline.codewithmuh.com

# ─── AI providers ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Voice providers ────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# REQUIRED IN PROD. Shared secret Vapi sends in the X-Vapi-Secret header on
# webhooks AND as a Bearer token on the custom-LLM endpoint. Without it,
# anyone who finds your URL can spam your Anthropic/OpenAI bill. Generate:
#   openssl rand -hex 32
# Then paste the same value into vapi.ai → assistant → Server URL → Secret.
VAPI_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── Frontend → Backend ─────────────────────────────────────────
# Server components (Next.js → Django) prefer INTERNAL; browser uses NEXT_PUBLIC.
# Locally:  http://backend:8000/api  (in compose)  /  http://localhost:8000/api  (browser)
# On Vercel: https://api.hearthline.codewithmuh.com/api for both.
INTERNAL_API_URL=http://backend:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api
